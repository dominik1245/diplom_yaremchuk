{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Доступний Дім: runserver",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/manage.py",
            "args": ["runserver", "127.0.0.1:8000"],
            "django": true,
            "cwd": "${workspaceFolder}",
            "justMyCode": false
        },
        {
            "name": "Доступний Дім: runserver (Python)",
            "type": "debugpy",
            "request": "launch",
            "module": "django",
            "args": ["runserver", "127.0.0.1:8000"],
            "django": true,
            "cwd": "${workspaceFolder}",
            "python": "${workspaceFolder}/venv/Scripts/python.exe",
            "justMyCode": false
        }
    ]
}
