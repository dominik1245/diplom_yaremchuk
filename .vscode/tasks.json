{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Доступний Дім: runserver",
            "type": "shell",
            "command": "${workspaceFolder}/venv/Scripts/python.exe",
            "args": ["manage.py", "runserver", "127.0.0.1:8000"],
            "options": {
                "cwd": "${workspaceFolder}",
                "env": {}
            },
            "group": "build",
            "presentation": {
                "reveal": "always",
                "panel": "new"
            },
            "problemMatcher": []
        }
    ]
}
